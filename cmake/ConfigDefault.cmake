# Default BLEND build settings.
# DO NOT EDIT THIS FILE!
#
# User-local settings belong in cmake/ConfigUser.cmake. To create that file,
# copy cmake/ConfigUserTemplate.cmake to cmake/ConfigUser.cmake and edit it.

set(BLEND_PACKAGE_NAME "BLEND")
set(BLEND_PACKAGE_DESCRIPTION_SUMMARY "Function localization using arbitrary support")

set(BLEND_PACKAGE_VERSION_MAJOR 1)
set(BLEND_PACKAGE_VERSION_MINOR 0)
set(BLEND_PACKAGE_VERSION_PATCH 2)
set(BLEND_PACKAGE_VERSION "${BLEND_PACKAGE_VERSION_MAJOR}.${BLEND_PACKAGE_VERSION_MINOR}.${BLEND_PACKAGE_VERSION_PATCH}")

set(BLEND_LIB_SOVERSION "${BLEND_PACKAGE_VERSION_MAJOR}")
set(BLEND_LIB_VERSION "${BLEND_PACKAGE_VERSION}")

if(NOT DEFINED CMAKE_CONFIGURATION_TYPES)
  if(NOT DEFINED CMAKE_BUILD_TYPE)
    set(CMAKE_BUILD_TYPE Release CACHE STRING "Choose the build type: Debug Release RelWithDebInfo MinSizeRel." FORCE)
  endif()
endif()

if(NOT DEFINED BLEND_BUILD_SHARED)
  set(BLEND_BUILD_SHARED TRUE)
endif()

if(NOT DEFINED BLEND_BUILD_STATIC)
  set(BLEND_BUILD_STATIC TRUE)
endif()

if(NOT DEFINED BLEND_BUILD_TESTS)
  set(BLEND_BUILD_TESTS OFF)
endif()

if(NOT DEFINED BLEND_BUILD_EXAMPLES)
  set(BLEND_BUILD_EXAMPLES OFF)
endif()
